# Secrets / local config
.env
*.local

# Node / frontend
node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
*.tsbuildinfo

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# dbt / warehouse — generated/downloaded; ignore contents but keep the
# explainer README in target/ (a dir-level ignore can't be negated per-file,
# so ignore the contents with /* and re-include the README).
warehouse/target/*
!warehouse/target/README.md
warehouse/dbt_packages/
warehouse/logs/
# dbt's anonymous-usage id: machine-local, not project source.
warehouse/.user.yml

# Downloaded data
data/ccrs/

# AWS CDK — installed packages and the synthesized CloudFormation output.
# Track the TypeScript source; ignore what npm and `cdk synth` generate.
infra/cdk/node_modules/
infra/cdk/cdk.out/
infra/cdk/*.tsbuildinfo
cdk.context.json

# IDE / OS
.vs/
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.user
Thumbs.db
.DS_Store

# Logs & scratch
logs/
*.log
tmp/
SierraPlan.txt
SECURITY.md
temporary screenshots/*

