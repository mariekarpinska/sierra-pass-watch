# Copy to .env (repo root) and adjust. Never commit .env.
# This single file is read by BOTH docker compose and the frontend dev server
# (Vite's envDir points at the repo root — see frontend/vite.config.ts).

# --- Postgres (docker-compose; pipeline connects with the same values) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app

# --- Pipeline (producer / consumer / backfill) ---
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=sierra.road.events
KAFKA_GROUP_ID=sierra-road-events
POLL_INTERVAL_SECONDS=300
# DRY_RUN=true makes the producer read tests/fixtures instead of live APIs.
DRY_RUN=false

# --- Frontend (Vite; only VITE_-prefixed vars reach the browser bundle) ---
# Backend origin the dev-server proxy forwards /api to:
VITE_API_PROXY_TARGET=http://localhost:5080
# Deployed API origin, set at build time in production:
# VITE_API_BASE_URL=https://api.example.com
