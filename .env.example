# Copy to .env (repo root) and adjust. Never commit .env.
# This single file is read by BOTH docker compose and the frontend dev server
# (Vite's envDir points at the repo root — see frontend/vite.config.ts).

# --- Postgres (docker-compose; pipeline connects with the same values) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app
# In the cloud, set DATABASE_URL instead of the parts above; it wins when set.
# Hosted Postgres (Neon/RDS) needs TLS, so include sslmode=require. This is the
# value stored as the GitHub secret DATABASE_URL for the ingest workflow, and in
# AWS SSM for the running API. See docs/deployment.md.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Pipeline (poll worker + backfill; no broker, ADR-0012) ---
# How often the poll worker's loop cycles when run with no --once flag.
POLL_INTERVAL_SECONDS=90
# DRY_RUN=true makes the poll worker read tests/fixtures instead of live APIs.
DRY_RUN=false

# --- Frontend (Vite; only VITE_-prefixed vars reach the browser bundle) ---
# Backend origin the dev-server proxy forwards /api to:
VITE_API_PROXY_TARGET=http://localhost:5080
# Deployed API origin, set at build time in production:
# VITE_API_BASE_URL=https://api.example.com
